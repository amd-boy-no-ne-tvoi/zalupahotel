DATABASE_URL="postgresql://pet_hotel_user:STRONG_PASSWORD@localhost:5432/pet_hotel"
JWT_ACCESS_SECRET="GENERATE_WITH: openssl rand -hex 32"
JWT_REFRESH_SECRET="GENERATE_WITH: openssl rand -hex 32"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
FRONTEND_URL="https://YOUR_DOMAIN.com"
NODE_ENV="production"
# Set to "false" only for HTTP-only demo deploys without a domain/SSL — browsers drop Secure cookies sent over plain HTTP.
COOKIE_SECURE="true"

# Web Push — generate new keys: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"
VAPID_SUBJECT="mailto:admin@YOUR_DOMAIN.com"
