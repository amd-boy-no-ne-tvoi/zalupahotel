# Database
POSTGRES_DB=pet_hotel
POSTGRES_USER=pethotel
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# JWT
JWT_SECRET=CHANGE_ME_at_least_32_chars_random
JWT_REFRESH_SECRET=CHANGE_ME_different_32_chars_random

# VAPID (push notifications) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
